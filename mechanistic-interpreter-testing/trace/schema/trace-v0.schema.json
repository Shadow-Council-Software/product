{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aois.local/schemas/trace-v0.schema.json",
  "title": "AOIS Inference Trace v0",
  "description": "Minimal orchestration-scale trace schema (AW-011). Calculator-class workflows only in v0.",
  "type": "object",
  "required": ["schema_version", "trace_id", "replay_envelope_id", "policy_snapshot_id", "spans"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "trace-v0"
    },
    "trace_id": {
      "type": "string",
      "minLength": 8
    },
    "replay_envelope_id": {
      "type": "string",
      "minLength": 1
    },
    "policy_snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "run_envelope": {
      "$ref": "#/$defs/run_envelope"
    },
    "trace_completeness_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "FR35-style completeness score for flagship workflows (AW-034)."
    },
    "spans": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/span" }
    }
  },
  "$defs": {
    "run_envelope": {
      "type": "object",
      "description": "E1 run boundary (AW-012 stub). Optional in v0 fixtures.",
      "additionalProperties": false,
      "properties": {
        "model_identity_hash": { "type": "string" },
        "toolchain_hash": { "type": "string" },
        "seed": { "type": "string" }
      }
    },
    "content_ref": {
      "type": "object",
      "required": ["ref_type", "digest"],
      "additionalProperties": false,
      "properties": {
        "ref_type": { "enum": ["inline", "blob"] },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "inline": {}
      }
    },
    "attachment": {
      "type": "object",
      "description": "Witness-only payload; excluded from span certificate digest (AW-004).",
      "required": ["attachment_id", "media_type"],
      "additionalProperties": false,
      "properties": {
        "attachment_id": { "type": "string" },
        "media_type": { "type": "string" },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "note": { "type": "string" }
      }
    },
    "choose_ledger": {
      "type": "object",
      "required": ["choose_source", "branch_inputs_digest", "outcome_digest"],
      "additionalProperties": false,
      "properties": {
        "choose_source": { "enum": ["policy", "tool", "model", "env"] },
        "branch_inputs_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "outcome_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "rejected_alts": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        }
      }
    },
    "commit_seal": {
      "type": "object",
      "required": ["durability_class"],
      "additionalProperties": false,
      "properties": {
        "durability_class": {
          "enum": ["ephemeral", "audit", "external"]
        }
      }
    },
    "span": {
      "type": "object",
      "required": [
        "span_id",
        "parent_span_id",
        "kind",
        "inputs_ref",
        "outputs_ref",
        "lifecycle_state"
      ],
      "additionalProperties": false,
      "properties": {
        "span_id": { "type": "string", "minLength": 1 },
        "parent_span_id": {
          "type": ["string", "null"],
          "description": "null for root span"
        },
        "kind": {
          "enum": ["OBSERVE", "TRANSFORM", "COMMIT", "CHOOSE", "DELEGATE"]
        },
        "lifecycle_state": {
          "enum": ["CAPTURED", "CANDIDATE", "FROZEN", "PROMOTED"]
        },
        "inputs_ref": { "$ref": "#/$defs/content_ref" },
        "outputs_ref": { "$ref": "#/$defs/content_ref" },
        "effect_class": {
          "enum": ["pure", "read", "write", "external"]
        },
        "choose_ledger": { "$ref": "#/$defs/choose_ledger" },
        "commit_seal": { "$ref": "#/$defs/commit_seal" },
        "delegate_target_hash": { "type": "string" },
        "capability_bound_hash": { "type": "string" },
        "attachments": {
          "type": "array",
          "items": { "$ref": "#/$defs/attachment" }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "CHOOSE" } } },
          "then": { "required": ["choose_ledger"] }
        },
        {
          "if": { "properties": { "kind": { "const": "COMMIT" } } },
          "then": { "required": ["commit_seal", "effect_class"] }
        },
        {
          "if": { "properties": { "kind": { "const": "DELEGATE" } } },
          "then": {
            "required": ["delegate_target_hash", "capability_bound_hash"]
          }
        },
        {
          "if": { "properties": { "kind": { "const": "TRANSFORM" } } },
          "then": {
            "properties": { "effect_class": { "const": "pure" } },
            "required": ["effect_class"]
          }
        }
      ]
    }
  }
}
